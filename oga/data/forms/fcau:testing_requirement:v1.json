{
    "schema": {
        "type": "object",
        "properties": {
            "labTestingStatus": {
            "type": "string",
            "title": "Are lab tests required?",
            "enum": ["Required", "Not Required"]
            },
            "requiredTests": {
            "type": "array",
            "title": "List Required Lab Tests",
            "description": "Add a new text box for each specific lab test required.",
            "items": {
                "type": "string",
                "title": "Test Name"
            }
            }
        },
        "required": ["labTestingStatus"],

        "allOf": [
            {
            "if": {
                "properties": {
                "labTestingStatus": {
                    "const": "Required"
                }
                }
            },
            "then": {
                "required": ["requiredTests"],
                "properties": {
                "requiredTests": {
                    "minItems": 1
                }
                }
            }
            }
        ]
    },
    "uiSchema": {
        "type": "VerticalLayout",
        "elements": [
            {
                "type": "Control",
                "scope": "#/properties/labTestingStatus",
                "options": {
                    "format": "radio"
                }
            },
            {
                "type": "Control",
                "scope": "#/properties/requiredTests",
                "rule": {
                    "effect": "SHOW",
                    "condition": {
                        "scope": "#/properties/labTestingStatus",
                        "schema": {
                            "const": "Required"
                        }
                    }
                }
            }
        ]
    }
}