# Thunder IdP Configuration

# Admin User Credentials
THUNDER_ADMIN_USERNAME=admin
THUNDER_ADMIN_PASSWORD=1234

# Thunder API Configuration
# Base URL for Thunder API used by bootstrap scripts inside thunder-setup
THUNDER_API_BASE=https://localhost:8090

# Public URL for Thunder (accessible from browser/clients)
# In production, this should be your actual domain
THUNDER_PUBLIC_URL=https://localhost:8090

# CORS Configuration
# Comma-separated list of allowed origins for CORS requests
# Add the URLs where your frontend applications are hosted
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176  
