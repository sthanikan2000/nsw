# Thunder IdP Configuration

# Required: Admin user credentials used by the bootstrap container
THUNDER_ADMIN_USERNAME=admin
THUNDER_ADMIN_PASSWORD=1234

# Required: Default password for sample users created by bootstrap
THUNDER_SAMPLE_USER_PASSWORD=1234

# Required: Default M2M client secret used by sample M2M apps
THUNDER_M2M_CLIENT_SECRET=1234

# Required: Base URL for Thunder API used by bootstrap scripts
# For local development this is typically https://localhost:8090
THUNDER_API_BASE=https://localhost:8090

# Required: Used by deployment.yaml placeholder
THUNDER_PUBLIC_URL=https://localhost:8090
THUNDER_PORT=8090
THUNDER_HOSTNAME=0.0.0.0

# Required: Additional CORS origins loaded into deployment.yaml
# Keep indices sequential with no gaps (0, 1, 2, ...).
# These are added on top of the localhost fallback origins in deployment.yaml.
THUNDER_CORS_ORIGINS_0=http://localhost:5173
THUNDER_CORS_ORIGINS_1=https://localhost:5173
THUNDER_CORS_ORIGINS_2=http://localhost:5174
THUNDER_CORS_ORIGINS_3=https://localhost:5174
THUNDER_CORS_ORIGINS_4=http://localhost:5175
THUNDER_CORS_ORIGINS_5=https://localhost:5175
THUNDER_CORS_ORIGINS_6=http://localhost:5176
THUNDER_CORS_ORIGINS_7=https://localhost:5176
THUNDER_CORS_ORIGINS_8=http://localhost:5177
THUNDER_CORS_ORIGINS_9=https://localhost:5177

# ----------------------
# Advanced / Optional
# Uncomment or add the variables below to override specific sample
# user passwords or M2M client secrets per-application.

# Per-sample-user overrides
# THUNDER_SAMPLE_NPQS_USER_PASSWORD=...
# THUNDER_SAMPLE_FCAU_USER_PASSWORD=...
# THUNDER_SAMPLE_IRD_USER_PASSWORD=...
# THUNDER_SAMPLE_CDA_USER_PASSWORD=...

# Per-M2M client secrets
# THUNDER_M2M_NPQS_SECRET=...
# THUNDER_M2M_FCAU_SECRET=...
# THUNDER_M2M_IRD_SECRET=...
# THUNDER_M2M_CDA_SECRET=...
